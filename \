.topbtn {
  font-size: 0;
  opacity: 0;
  pointer-events: none;
  position: fixed;
  bottom: 20px;
  right: 30px;
  z-index: 599;
  border: none;
  outline: none;
  background-color: transparent;
  cursor: pointer;
  margin: 0;
  padding: 0;
  box-shadow:0 4px 10px 0 rgba(0,0,0,0.2),0 4px 20px 0 rgba(0,0,0,0.19);
  transition: opacity 100ms ease-in;
  border-radius:50%;
  & svg {
    background-color: transparent
  }

