// Styling PDF links and external links
a[href$="\.pdf" i]::after {
    font-family: "Font Awesome 6 Free";
    content: '\f1c1';
    font-weight: 400;
    // font-size: .6em;
    margin-left: .3em;
    text-decoration: none;
    background-color: inherit;
    color: var(--color-1-dark);
    display: inline-block;
}

// Styling external links
a[href^="http" i]::after {
    font-family: "Font Awesome 6 Free";
    content: '\f35d';
    font-weight: 900;
    font-size: .6em;
    margin: 0 0 .05em .4em;
    color: var(--color-triad-2-dark);
    text-decoration: none;
    background-color: transparent;
    display: inline-block;
}

a[href^="https://m.smrh.xyz/" i]::after {
  content: none;
}

a[href^="https://www.summerhays.net/" i]::after {
  content: none;
}

// Creating a custom scroll bar, matching momism theme
body::-webkit-scrollbar {
  width: .5em;
}

body::-webkit-scrollbar-track {
  background-color: var(--scrollbar-back);
  border-radius: 100vw;
  margin-block: .05em;
}

body::-webkit-scrollbar-thumb {
  //background-color: linear-gradient(var(--color-1, var(--color-1-dark));
  background-color: var(--color-1-light);
  border: .05em solid var(--scrollbar-back);
  opacity: 70%;
  border-radius: 100vw;
  transition: background .3s;
  &:hover {
    background-color: var(--color-1);
  }
  &:active {
    background-color: var(--color-1-dark);
  }
}


@supports (scrollbar-color: red blue) {
  * {
    scrollbar-color: var(--scrollbar-thumb) var(--scrollbar-back);
  }
}
